{
  "name": "secure-exam-system",
  "version": "1.0.18",
  "description": "SecurePro AI Exam Proctoring System",
  "main": "main.js",
  "author": "Admin",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac dmg zip --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac dmg zip --publish always"
  },
  "build": {
    "appId": "com.securepro.exam",
    "productName": "SecurePro",
    "copyright": "Copyright © 2025 SecurePro",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SecurePro-Setup.${ext}",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "SecurePro.${ext}",
      "icon": "assets/icon.png",
      "category": "public.app-category.education"
    },
    "dmg": {
      "title": "SecurePro Installer",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SecurePro",
      "differentialPackage": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SupratheekReddy",
        "repo": "securepro-releases",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "models/**/*",
      "package.json",
      "!dist/**",
      "!.github/**",
      "!node_modules/.cache/**",
      "!**/*.map",
      "!**/*.log",
      "!**/*.rar",
      "!**/*.zip",
      "!**/*.md",
      "!build_log.txt",
      "!vercel_out.txt"
    ],
    "afterSign": "build/notarize.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "@electron/notarize": "^2.5.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "pdf-parse": "^2.4.5"
  }
}